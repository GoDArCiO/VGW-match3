# Asset meta files for ignored folders are not needed
!/[Aa]ssets/**/*.meta

# Visual Studio / Rider / VS Code project files
/.vs/
/.vsconfig
/.idea/
*.csproj
*.unityproj
*.sln
*.user
*.userprefs
