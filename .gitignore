# OS / editor cruft
.DS_Store
Thumbs.db
*~

# Unity crash / build reports
sysinfo.txt
/[Aa]ssets/[Aa]ssetStoreTools*
/[Aa]ssets/[Pp]lugins/[Ee]ditor/JetBrains*
crashlytics-build.properties
ExportedObj/
*.apk
*.aab
*.unitypackage
*.app
