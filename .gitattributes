# Normalize line endings: Git stores LF, checks out native. Stops CRLF churn across branches/machines.
* text=auto

# Source & text — always LF in the repo
*.cs        text diff=csharp eol=lf
*.ps1       text eol=lf
*.md        text eol=lf
*.json      text eol=lf
*.txt       text eol=lf
*.uxml      text eol=lf
*.uss       text eol=lf
*.shader    text eol=lf
*.cginc     text eol=lf
*.hlsl      text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf

# Unity YAML assets — treat as text, merge with Unity's smart merge tool (unityyamlmerge)
*.unity     text merge=unityyamlmerge eol=lf
*.prefab    text merge=unityyamlmerge eol=lf
*.asset     text merge=unityyamlmerge eol=lf
*.mat       text merge=unityyamlmerge eol=lf
*.anim      text merge=unityyamlmerge eol=lf
*.controller text merge=unityyamlmerge eol=lf
*.meta      text eol=lf
*.inputactions text eol=lf

# Binary assets — never normalize or diff
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.psd       binary
*.tga       binary
*.fbx       binary
*.wav       binary
*.mp3       binary
*.ogg       binary
*.ttf       binary
*.otf       binary
*.dll       binary
*.so        binary
*.a         binary
*.cubemap   binary
*.unitypackage binary
*.wlt       binary
